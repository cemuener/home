---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import ScrollNav from '../../../components/ScrollNav.astro';
import { translations } from '../../../i18n/translations';

const t = translations.de;
const d = t.developer;
const lang = 'de';
const service = 'developer';

// level: 3 = Expert · 2 = Proficient · 1 = Familiar
const skills = [
  { name: 'TypeScript', icon: '🔷', category: 'Language', level: 3 },
  { name: 'JavaScript', icon: '🟡', category: 'Language', level: 3 },
  { name: 'React', icon: '⚛️', category: 'Frontend', level: 3 },
  { name: 'Astro', icon: '🚀', category: 'Frontend', level: 3 },
  { name: 'HTML / CSS', icon: '🎨', category: 'Frontend', level: 3 },
  { name: 'SCSS / Sass', icon: '💅', category: 'Frontend', level: 2 },
  { name: 'Node.js', icon: '🟢', category: 'Backend', level: 2 },
  { name: 'REST APIs', icon: '🔌', category: 'Backend', level: 2 },
  { name: 'Git & GitHub', icon: '🐙', category: 'Tools', level: 3 },
  { name: 'Figma', icon: '🖌️', category: 'Tools', level: 2 },
  { name: 'Docker', icon: '🐳', category: 'Tools', level: 1 },
  { name: 'Linux / CLI', icon: '🖥️', category: 'Tools', level: 2 },
];

const skillLabel = (level: number) =>
  level === 3 ? d.skillExpert : level === 2 ? d.skillProficient : d.skillFamiliar;
---

<BaseLayout
  title={d.title}
  description={d.metaDescription}
  lang={lang}
  service={service}
>
  <Navigation service="developer" />
  <ScrollNav service="developer" />

  <main class="dev-portfolio">
    <div class="dev-portfolio__container">

      <!-- Hero -->
      <section class="portfolio-hero">
        <div class="portfolio-hero__avatar">
          <img
            src="/assets/images/developer/profile_professional.jpg"
            alt="Cem Üner – Full-Stack Developer"
            class="portfolio-hero__avatar-img"
            width="160"
            height="160"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="portfolio-hero__badge">{d.heroBadge}</div>
        <h1 class="portfolio-hero__title text--gradient-dev">{d.heroTitle}</h1>
        <p class="portfolio-hero__tagline">{d.heroTagline}</p>
        <div class="portfolio-hero__ctas">
          <a href="#cv" class="btn btn--primary" id="hero-cv-btn">
            <span>📄</span> {d.cvView}
          </a>
          <a href="https://github.com/cuener" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
            <span>🐙</span> GitHub
          </a>
          <a href="mailto:dj-cem.uener@outlook.com" class="btn btn--outline">
            <span>✉️</span> {d.contactCta}
          </a>
        </div>
      </section>

      <!-- About -->
      <section class="portfolio-about" id="about">
        <div class="portfolio-about__content">
          <div class="portfolio-about__text">
            <h2 class="section-title">{d.aboutTitle}</h2>
            <p>{d.aboutPara1}</p>
            <p>{d.aboutPara2}</p>
          </div>
          <div class="portfolio-about__meta">
            <div class="meta-card">
              <span class="meta-card__icon">📍</span>
              <span>München, Deutschland</span>
            </div>
            <div class="meta-card">
              <span class="meta-card__icon">💼</span>
              <span>Full-Stack Developer</span>
            </div>
            <div class="meta-card">
              <span class="meta-card__icon">🎓</span>
              <span>M.Sc Human-Computer-Interaction</span>
            </div>
            <div class="meta-card">
              <span class="meta-card__icon">🌍</span>
              <span>Deutsch, Englisch, Türkisch</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Tech Stack -->
      <section class="portfolio-skills" id="skills">
        <h2 class="section-title">{d.skillsTitle}</h2>
        <div class="skills-grid">
          {skills.map(skill => (
            <div class="skill-card">
              <span class="skill-card__icon">{skill.icon}</span>
              <span class="skill-card__name">{skill.name}</span>
              <span class="skill-card__category">{skill.category}</span>
              <div class="skill-card__level" aria-label={skillLabel(skill.level)}>
                {[1,2,3].map(dot => (
                  <span class={`skill-dot${dot <= skill.level ? ' skill-dot--active' : ''}`}></span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section class="portfolio-projects" id="projects">
        <h2 class="section-title">{d.projectsTitle}</h2>
        <p class="section-subtitle">{d.projectsSubtitle}</p>
        <div class="projects-grid">
          <!-- Projekt 1 -->
          <div class="project-card">
            <div class="project-card__header">
              <span class="project-card__emoji">🌐</span>
              <div class="project-card__tags">
                <span class="tag">Astro</span>
                <span class="tag">TypeScript</span>
                <span class="tag">SCSS</span>
              </div>
            </div>
            <h3 class="project-card__title">cemuener.de</h3>
            <p class="project-card__desc">{d.project1Desc}</p>
            <div class="project-card__links">
              <a href="https://cemuener.de" target="_blank" rel="noopener noreferrer" class="project-link">
                🔗 Live ansehen
              </a>
              <a href="https://github.com/cuener/home" target="_blank" rel="noopener noreferrer" class="project-link project-link--ghost">
                🐙 GitHub
              </a>
            </div>
          </div>
          <!-- Projekt 2 -->
          <div class="project-card">
            <div class="project-card__header">
              <span class="project-card__emoji">🧪</span>
              <div class="project-card__tags">
                <span class="tag">React</span>
                <span class="tag">TypeScript</span>
                <span class="tag">Research</span>
              </div>
            </div>
            <h3 class="project-card__title">{d.project2Title}</h3>
            <p class="project-card__desc">{d.project2Desc}</p>
            <div class="project-card__links">
              <span class="project-link project-link--muted">🔒 Privat / Akademisch</span>
            </div>
          </div>
          <!-- Projekt 3 -->
          <div class="project-card">
            <div class="project-card__header">
              <span class="project-card__emoji">🎛️</span>
              <div class="project-card__tags">
                <span class="tag">Node.js</span>
                <span class="tag">React</span>
                <span class="tag">REST API</span>
              </div>
            </div>
            <h3 class="project-card__title">{d.project3Title}</h3>
            <p class="project-card__desc">{d.project3Desc}</p>
            <div class="project-card__links">
              <span class="project-link project-link--muted">🚧 In Entwicklung</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Aktueller Fokus -->
      <section class="portfolio-focus">
        <div class="focus-card">
          <div class="focus-card__icon">🎯</div>
          <div class="focus-card__content">
            <h2>{d.focusTitle}</h2>
            <p>{d.focusPara}</p>
          </div>
        </div>
      </section>

      <!-- CV Viewer -->
      <section class="portfolio-cv" id="cv">
        <div class="cv-viewer">
          <div class="cv-viewer__header">
            <div class="cv-viewer__title">
              <span>📄</span>
              <div>
                <h2>{d.cvTitle}</h2>
                <span class="cv-viewer__note">{d.cvNote}</span>
              </div>
            </div>
            <div class="cv-viewer__actions">
              <button
                id="cv-toggle-btn"
                class="btn btn--primary"
                type="button"
                data-open={d.cvView}
                data-close={d.cvClose}
              >
                <span id="cv-toggle-icon">👁️</span>
                <span id="cv-toggle-text">{d.cvView}</span>
              </button>
              <a
                href="/assets/cv-latest.pdf"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--secondary btn--sm"
              >
                ↗ {d.cvOpenTab}
              </a>
            </div>
          </div>
          <div class="cv-viewer__body" id="cv-body">
            <div class="cv-viewer__frame-wrap">
              <iframe
                data-src="/assets/cv-latest.pdf#toolbar=0&navpanes=0"
                class="cv-viewer__iframe"
                title="CV Cem Üner"
              >
                <p>{d.cvFallback} <a href="/assets/cv-latest.pdf" download="CV_Cem_Uener.pdf">{d.cvDownload}</a>.</p>
              </iframe>
            </div>
          </div>
        </div>
      </section>

      <!-- Links -->
      <section class="portfolio-links">
        <h2 class="section-title">{d.linksTitle}</h2>
        <div class="links-grid">
          <a href="https://github.com/cuener" target="_blank" rel="noopener noreferrer" class="link-card">
            <span class="link-card__icon">🐙</span>
            <div>
              <span class="link-card__title">GitHub</span>
              <span class="link-card__desc">github.com/cuener</span>
            </div>
          </a>
          <a href="https://linkedin.com/in/cemuener" target="_blank" rel="noopener noreferrer" class="link-card">
            <span class="link-card__icon">💼</span>
            <div>
              <span class="link-card__title">LinkedIn</span>
              <span class="link-card__desc">linkedin.com/in/cemuener</span>
            </div>
          </a>
          <a href="/de/dj/" class="link-card">
            <span class="link-card__icon">🎵</span>
            <div>
              <span class="link-card__title">{d.djServiceLink}</span>
              <span class="link-card__desc">DJ Cem Üner</span>
            </div>
          </a>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<style lang="scss">
  @use '../../../styles/variables' as *;
  @use '../../../styles/mixins' as *;

  .dev-portfolio {
    min-height: 100vh;
    padding-top: 80px;
    background: $bg-dark;
    color: $text-primary;

    @include element('container') {
      @include container;
      padding-top: $gap-xl;
      padding-bottom: $gap-xl;
      display: flex;
      flex-direction: column;
      gap: $gap-xl;
    }
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    margin-bottom: $gap-sm;
    background: $dev-gradient;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;

    @media (forced-colors: active) {
      -webkit-text-fill-color: unset;
      background: none;
      color: ButtonText;
    }
  }

  .section-subtitle {
    color: $text-secondary;
    margin-bottom: $gap-lg;
    font-size: 1.1rem;
  }

  // ── Hero ──────────────────────────────
  .portfolio-hero {
    text-align: center;
    padding: $gap-xl 0 $gap-lg;
    position: relative;
    overflow: hidden;
    border-radius: $radius-lg;
    background: rgba($dev-primary, 0.04);
    border: 1px solid rgba($dev-primary, 0.1);

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba($dev-primary, 0.2) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
      z-index: 0;
    }

    & > * {
      position: relative;
      z-index: 1;
    }

    @include element('avatar') {
      display: flex;
      justify-content: center;
      margin-bottom: $gap-md;
    }

    @include element('avatar-img') {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      border: 3px solid rgba($dev-primary, 0.5);
      box-shadow: 0 0 0 6px rgba($dev-primary, 0.1), $shadow-lg;
    }

    @include element('badge') {
      display: inline-block;
      padding: 0.5rem 1.25rem;
      background: rgba($dev-primary, 0.15);
      border: 1px solid rgba($dev-primary, 0.4);
      border-radius: $radius-xl;
      font-size: 0.9rem;
      color: $dev-secondary;
      margin-bottom: $gap-md;
      letter-spacing: 0.05em;
    }

    @include element('title') {
      font-size: clamp(3rem, 8vw, 5rem);
      font-weight: 900;
      margin-bottom: $gap-sm;
      line-height: 1.1;
    }

    @include element('tagline') {
      font-size: clamp(1rem, 2.5vw, 1.4rem);
      color: $text-secondary;
      font-family: 'Courier New', monospace;
      margin-bottom: $gap-lg;
      letter-spacing: 0.04em;
    }

    @include element('ctas') {
      display: flex;
      gap: $gap-sm;
      justify-content: center;
      flex-wrap: wrap;
    }
  }

  // ── About ─────────────────────────────
  .portfolio-about {
    @include element('content') {
      display: grid;
      grid-template-columns: 1fr;
      gap: $gap-lg;

      @include above($tablet) {
        grid-template-columns: 1.5fr 1fr;
        align-items: start;
      }
    }

    @include element('text') {
      p {
        color: $text-secondary;
        line-height: 1.8;
        margin-bottom: $gap-md;
        font-size: 1.05rem;
        &:last-child { margin-bottom: 0; }
      }
    }

    @include element('meta') {
      display: flex;
      flex-direction: column;
      gap: $gap-sm;
    }
  }

  .meta-card {
    display: flex;
    align-items: center;
    gap: $gap-sm;
    padding: 1rem 1.25rem;
    background: rgba($dev-primary, 0.08);
    border: 1px solid rgba($dev-primary, 0.2);
    border-radius: $radius-md;
    font-size: 0.95rem;
    color: $text-secondary;
    @include smooth-transition;

    &:hover {
      background: rgba($dev-primary, 0.15);
      color: $text-primary;
    }

    @include element('icon') { font-size: 1.2rem; }
  }

  // ── Skills ────────────────────────────
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: $gap-sm;

    @include above($tablet) {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }

  .skill-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1rem;
    background: rgba($dev-primary, 0.08);
    border: 1px solid rgba($dev-primary, 0.2);
    border-radius: $radius-lg;
    text-align: center;
    @include smooth-transition;

    &:hover {
      background: rgba($dev-primary, 0.18);
      border-color: rgba($dev-secondary, 0.5);
      transform: translateY(-3px);
      box-shadow: $shadow-md;
    }

    @include element('icon') { font-size: 1.75rem; }
    @include element('name') { font-weight: 600; font-size: 0.95rem; color: $text-primary; }
    @include element('category') {
      font-size: 0.75rem;
      color: $dev-secondary;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    @include element('level') {
      display: flex;
      gap: 4px;
      align-items: center;
      margin-top: 2px;
    }
  }

  .skill-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba($dev-primary, 0.15);
    border: 1px solid rgba($dev-primary, 0.35);

    &--active {
      background: $dev-secondary;
      border-color: $dev-secondary;
      box-shadow: 0 0 4px rgba($dev-secondary, 0.5);
    }
  }

  // ── Projects ──────────────────────────
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: $gap-md;

    @include above($tablet) { grid-template-columns: repeat(2, 1fr); }
    @include above($desktop) { grid-template-columns: repeat(3, 1fr); }
  }

  .project-card {
    background: rgba($dev-primary, 0.06);
    border: 1px solid rgba($dev-primary, 0.2);
    border-radius: $radius-lg;
    padding: $gap-md;
    display: flex;
    flex-direction: column;
    gap: $gap-sm;
    @include smooth-transition;

    &:hover {
      background: rgba($dev-primary, 0.12);
      border-color: rgba($dev-secondary, 0.4);
      transform: translateY(-4px);
      box-shadow: $shadow-lg;
    }

    @include element('header') {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    @include element('emoji') { font-size: 2rem; }

    @include element('tags') {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }

    @include element('title') {
      font-size: 1.25rem;
      font-weight: 700;
      color: $text-primary;
      margin: 0;
    }

    @include element('desc') {
      color: $text-secondary;
      line-height: 1.7;
      font-size: 0.95rem;
      flex: 1;
    }

    @include element('links') {
      display: flex;
      gap: $gap-sm;
      flex-wrap: wrap;
      margin-top: auto;
    }
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: rgba($dev-secondary, 0.15);
    color: $dev-secondary;
    border-radius: $radius-sm;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 1rem;
    border-radius: $radius-md;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    background: rgba($dev-secondary, 0.15);
    color: $dev-secondary;
    @include smooth-transition;

    &:hover {
      background: rgba($dev-secondary, 0.3);
      transform: translateY(-1px);
    }

    @include modifier('ghost') {
      background: transparent;
      border: 1px solid rgba($dev-primary, 0.3);
      color: $text-secondary;

      &:hover {
        border-color: $dev-primary;
        color: $text-primary;
      }
    }

    @include modifier('muted') {
      background: transparent;
      border: 1px solid rgba($dev-primary, 0.15);
      color: rgba($text-secondary, 0.6);
      cursor: default;
      pointer-events: none;
      font-style: italic;
    }
  }

  // ── CV Download ───────────────────────
  .portfolio-cv {
    scroll-margin-top: 100px;
  }

  .cv-viewer {
    border: 1px solid rgba($dev-primary, 0.3);
    border-radius: $radius-lg;
    overflow: hidden;
    background: rgba($dev-primary, 0.06);

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: $gap-sm;
      padding: $gap-md $gap-lg;
      background: rgba($dev-primary, 0.08);
    }

    &__title {
      display: flex;
      align-items: center;
      gap: $gap-sm;

      span:first-child { font-size: 1.75rem; }

      h2 {
        font-size: 1.2rem;
        font-weight: 700;
        color: $text-primary;
        margin: 0 0 0.2rem;
      }
    }

    &__note {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      background: rgba($dev-secondary, 0.1);
      color: $dev-secondary;
      border-radius: $radius-sm;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.04em;
    }

    &__actions {
      display: flex;
      gap: $gap-sm;
      align-items: center;
      flex-wrap: wrap;
    }

    &__body {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.45s cubic-bezier(0.4, 0, 0.2, 1);

      &.is-open {
        grid-template-rows: 1fr;
      }
    }

    &__frame-wrap {
      overflow: hidden;
      min-height: 0;
    }

    &__iframe {
      width: 100%;
      height: 80vh;
      min-height: 480px;
      border: none;
      display: block;
      background: #fff;
    }
  }

  .portfolio-focus {
    .focus-card {
      display: flex;
      align-items: flex-start;
      gap: $gap-md;
      padding: $gap-md $gap-lg;
      background: rgba($dev-primary, 0.07);
      border: 1px solid rgba($dev-secondary, 0.3);
      border-left: 4px solid $dev-secondary;
      border-radius: $radius-lg;

      &__icon { font-size: 1.75rem; flex-shrink: 0; padding-top: 2px; }

      &__content {
        h2 {
          font-size: 1.1rem;
          font-weight: 700;
          color: $dev-secondary;
          margin-bottom: 0.4rem;
          text-transform: uppercase;
          letter-spacing: 0.06em;
        }
        p {
          color: $text-secondary;
          line-height: 1.7;
          font-size: 0.975rem;
          margin: 0;
        }
      }
    }
  }


  // ── Links ─────────────────────────────
  .links-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: $gap-sm;

    @include above($tablet) { grid-template-columns: repeat(3, 1fr); }
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: $gap-sm;
    padding: 1.25rem 1.5rem;
    background: rgba($dev-primary, 0.08);
    border: 1px solid rgba($dev-primary, 0.2);
    border-radius: $radius-lg;
    text-decoration: none;
    @include smooth-transition;

    &:hover {
      background: rgba($dev-primary, 0.18);
      border-color: rgba($dev-secondary, 0.5);
      transform: translateY(-3px);
      box-shadow: $shadow-md;
    }

    @include element('icon') { font-size: 1.75rem; flex-shrink: 0; }
    @include element('title') { font-weight: 700; color: $text-primary; display: block; font-size: 1rem; }
    @include element('desc') { color: $text-secondary; font-size: 0.85rem; display: block; }
  }

  // ── Buttons ───────────────────────────
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: $radius-md;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    @include smooth-transition;
    cursor: pointer;

    @include modifier('primary') {
      background: $dev-gradient;
      color: white;
      border: none;

      &:hover {
        transform: translateY(-2px);
        box-shadow: $shadow-lg;
      }
    }

    @include modifier('secondary') {
      background: transparent;
      border: 2px solid rgba($dev-primary, 0.4);
      color: $text-primary;

      &:hover {
        border-color: $dev-primary;
        color: $dev-primary;
        transform: translateY(-2px);
      }
    }

    @include modifier('outline') {
      background: transparent;
      border: 2px solid rgba($dev-secondary, 0.5);
      color: $dev-secondary;

      &:hover {
        background: rgba($dev-secondary, 0.1);
        border-color: $dev-secondary;
        transform: translateY(-2px);
      }
    }

    @include modifier('lg') {
      padding: 1rem 2rem;
      font-size: 1.05rem;
    }

    @include modifier('sm') {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
    }
  }
</style>

<script>
  const body = document.getElementById('cv-body') as HTMLElement;
  const toggleBtn = document.getElementById('cv-toggle-btn') as HTMLButtonElement;
  const toggleText = document.getElementById('cv-toggle-text') as HTMLElement;
  const toggleIcon = document.getElementById('cv-toggle-icon') as HTMLElement;
  const iframe = document.querySelector('.cv-viewer__iframe') as HTMLIFrameElement;

  const OPEN_LABEL = toggleBtn?.dataset.open ?? 'Lebenslauf ansehen';
  const CLOSE_LABEL = toggleBtn?.dataset.close ?? 'Schließen';
  let loaded = false;

  function openViewer() {
    if (!loaded && iframe?.dataset.src) {
      iframe.src = iframe.dataset.src;
      loaded = true;
    }
    body.classList.add('is-open');
    toggleIcon.textContent = '✕';
    toggleText.textContent = CLOSE_LABEL;
    document.getElementById('cv')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function toggleViewer() {
    if (body.classList.contains('is-open')) {
      body.classList.remove('is-open');
      toggleIcon.textContent = '👁️';
      toggleText.textContent = OPEN_LABEL;
    } else {
      openViewer();
    }
  }

  toggleBtn?.addEventListener('click', toggleViewer);

  document.getElementById('hero-cv-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    openViewer();
  });
</script>

