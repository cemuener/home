---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import { translations } from '../../i18n/translations';

const t = translations.de;
const lang = 'de';
const title = `${t.impressum.title} | Cem Üner`;
const description = t.impressum.metaDescription;
---

<BaseLayout title={title} description={description} lang={lang}>
  <Navigation />

  <main class="impressum-page">
    <div class="impressum-page__container">
      <h1 class="impressum-page__title" data-i18n="impressum.title">{t.impressum.title}</h1>

      <section class="impressum-page__section">
        <h2 class="impressum-page__heading" data-i18n="impressum.tmgHeading">{t.impressum.tmgHeading}</h2>
        <div class="impressum-page__content">
          <p><strong>Cem Üner</strong></p>
          <p>DJ-Performances<br/>Schlörstr. 21a<br/>80634 München</p>
          <p>Germany</p>
        </div>
      </section>

      <section class="impressum-page__section">
        <h2 class="impressum-page__heading" data-i18n="impressum.contactHeading">{t.impressum.contactHeading}</h2>
        <div class="impressum-page__content">
          <p><strong>Telefon:</strong> +49 171 5279579</p>
          <p><strong>E-Mail:</strong> dj-cem.uener@outlook.com</p>
        </div>
      </section>

      <section class="impressum-page__section">
        <h2 class="impressum-page__heading" data-i18n="impressum.disputeHeading">{t.impressum.disputeHeading}</h2>
        <div class="impressum-page__content">
          <p data-i18n="impressum.disputePara1">{t.impressum.disputePara1}</p>
          <p data-i18n="impressum.disputeSource">{t.impressum.disputeSource}</p>
          <p>
            <span data-i18n="impressum.disputePara2">{t.impressum.disputePara2}</span>
            <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">
              https://ec.europa.eu/consumers/odr/
            </a>
          </p>
        </div>
      </section>

      <section class="impressum-page__section">
        <h2 class="impressum-page__heading" data-i18n="impressum.liabilityContentHeading">{t.impressum.liabilityContentHeading}</h2>
        <div class="impressum-page__content">
          <p data-i18n="impressum.liabilityContent">{t.impressum.liabilityContent}</p>
        </div>
      </section>

      <section class="impressum-page__section">
        <h2 class="impressum-page__heading" data-i18n="impressum.liabilityLinksHeading">{t.impressum.liabilityLinksHeading}</h2>
        <div class="impressum-page__content">
          <p data-i18n="impressum.liabilityLinks">{t.impressum.liabilityLinks}</p>
        </div>
      </section>

      <div class="impressum-page__back">
        <a href="/de/dj/" class="btn btn--secondary" data-i18n="impressum.backToHome">{t.impressum.backToHome}</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .impressum-page {
    min-height: 100vh;
    padding-top: 80px;
    background: $bg-dark;
    color: $text-primary;

    @include element('container') {
      @include container;
      padding: $gap-xl 2rem;
      max-width: 800px;
    }

    @include element('title') {
      font-size: clamp(2rem, 5vw, 3rem);
      margin-bottom: $gap-lg;
      background: $dj-gradient;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    @include element('section') {
      margin-bottom: $gap-lg;
      padding-bottom: $gap-md;
      border-bottom: 1px solid $border;

      &:last-of-type {
        border-bottom: none;
      }
    }

    @include element('heading') {
      font-size: clamp(1.25rem, 3vw, 1.5rem);
      margin-bottom: $gap-md;
      color: $accent;
    }

    @include element('content') {
      line-height: 1.8;

      p {
        margin-bottom: $gap-sm;
        color: $text-secondary;

        &:last-child {
          margin-bottom: 0;
        }

        strong {
          color: $text-primary;
        }
      }

      a {
        color: $accent;
        text-decoration: underline;
        @include smooth-transition;

        &:hover {
          color: $dj-primary;
        }

        &:focus-visible {
          outline: 2px solid $accent;
          outline-offset: 2px;
          border-radius: $radius-sm;
        }
      }
    }

    @include element('back') {
      margin-top: $gap-xl;
      text-align: center;
    }
  }

  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: $radius-md;
    font-weight: 600;
    @include smooth-transition;
    text-decoration: none;

    @include modifier('secondary') {
      border: 2px solid $border;
      color: $text-primary;

      &:hover {
        border-color: $accent;
        color: $accent;
        transform: translateY(-2px);
      }

      &:focus-visible {
        outline: 2px solid $accent;
        outline-offset: 4px;
      }
    }
  }
</style>

