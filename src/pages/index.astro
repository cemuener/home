// Redirect root to /de/dj/ by default (primary service in German)
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="refresh" content="0; url=/de/dj/" />
  <link rel="canonical" href="https://cemuener.de/de/dj/" />
  <title>DJ Cem Üner – München</title>

  <!-- Open Graph for link previews on root URL -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://cemuener.de/" />
  <meta property="og:title" content="DJ Cem Üner – München" />
  <meta property="og:description" content="DJ aus München mit einem feinen Gespür für Menschen und Atmosphäre – House, Afro & Oriental." />
  <meta property="og:image" content="https://cemuener.de/assets/images/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:alt" content="DJ Cem Üner at the decks" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="DJ Cem Üner" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content="DJ Cem Üner – München" />
  <meta property="twitter:description" content="DJ aus München mit einem feinen Gespür für Menschen und Atmosphäre – House, Afro & Oriental." />
  <meta property="twitter:image" content="https://cemuener.de/assets/images/og-image.jpg" />
  <meta property="twitter:image:alt" content="DJ Cem Üner at the decks" />

  <link rel="image_src" href="https://cemuener.de/assets/images/og-image.jpg" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <script>
    // Client-side redirect with hash preservation
    const hash = window.location.hash;
    window.location.href = '/de/dj/' + hash;
  </script>
  <noscript>
    <p>Redirecting to <a href="/de/dj/">DJ Services</a>...</p>
  </noscript>
</body>
</html>
