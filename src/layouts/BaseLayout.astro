---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  lang?: 'de' | 'en';
  service?: 'dj' | 'portfolio';
  hideFooter?: boolean;
}

import Footer from '../components/Footer.astro';

const {
  title = 'DJ Cem Üner',
  description = 'Multi-talented professional: DJ, Indoor Cycling Coach, and Full-Stack Developer based in Germany.',
  image = '/assets/images/dj/controller_close.jpg',
  type = 'website',
  lang = 'de',
  service = 'dj',
  hideFooter = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);

// Image dimensions for OG tags — controller_close.jpg is 3648×5472 (portrait)
// We declare the actual dimensions so Google/crawlers know what to expect.
const ogImageWidth = image.includes('controller_close') ? 3648 : 1200;
const ogImageHeight = image.includes('controller_close') ? 5472 : 630;
const faviconPath = '/favicon.svg';

// image_src link hint — used by some crawlers as a thumbnail signal
const imageSrcURL = ogImageURL.toString();

// Structured Data (JSON-LD) for SEO and LLM discoverability
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://cemuener.de/#person',
      name: 'Cem Üner',
      url: 'https://cemuener.de',
      image: {
        '@type': 'ImageObject',
        '@id': 'https://cemuener.de/#primary-image',
        url: 'https://cemuener.de/assets/images/dj/controller_close.jpg',
        width: 3648,
        height: 5472,
        caption: 'DJ Cem Üner at the decks'
      },
      sameAs: [
        'https://www.instagram.com/cemuener/',
        'https://soundcloud.com/cemuener',
        'https://github.com/cuener',
        'https://linkedin.com/in/cemuener'
      ],
      jobTitle: ['DJ', 'Indoor Cycling Coach', 'Full-Stack Developer'],
      knowsAbout: [
        'DJing',
        'Music Production',
        'Indoor Cycling',
        'Fitness Coaching',
        'Web Development',
        'TypeScript',
        'React',
        'Node.js'
      ],
      description: 'Multi-talented professional: DJ, Indoor Cycling Coach, and Full-Stack Developer based in Germany.',
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'DE'
      }
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalURL}#webpage`,
      url: canonicalURL.toString(),
      name: title,
      description: description,
      isPartOf: { '@id': 'https://cemuener.de/#website' },
      about: { '@id': 'https://cemuener.de/#person' },
      mainEntity: { '@id': 'https://cemuener.de/#person' },
      primaryImageOfPage: { '@id': 'https://cemuener.de/#primary-image' },
      inLanguage: lang === 'en' ? 'en-US' : 'de-DE'
    },
    {
      '@type': 'WebSite',
      '@id': 'https://cemuener.de/#website',
      url: 'https://cemuener.de',
      name: 'DJ Cem Üner',
      description: 'Portfolio website of Cem Üner - DJ, Indoor Cycling Coach, and Full-Stack Developer',
      publisher: {
        '@id': 'https://cemuener.de/#person'
      },
      primaryImageOfPage: {
        '@id': 'https://cemuener.de/#primary-image'
      },
      inLanguage: 'de-DE',
      copyrightYear: new Date().getFullYear(),
      copyrightHolder: {
        '@id': 'https://cemuener.de/#person'
      }
    },
    {
      '@type': 'ProfessionalService',
      '@id': 'https://cemuener.de/#dj-service',
      name: 'DJ Cem Üner',
      description: 'Professional DJ services specializing in House, Afro, and Oriental music',
      url: 'https://cemuener.de/de/dj/',
      sameAs: ['https://cemuener.de/en/dj/'],
      telephone: '+49-171-5279579',
      image: {
        '@id': 'https://cemuener.de/#primary-image'
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'München',
        addressRegion: 'Bayern',
        addressCountry: 'DE'
      },
      provider: {
        '@id': 'https://cemuener.de/#person'
      },
      areaServed: 'DE',
      serviceType: ['DJ Services', 'Event Entertainment', 'Music Performance']
    },
    {
      '@type': 'EducationalOrganization',
      '@id': 'https://cemuener.de/#coaching-service',
      name: 'Indoor Cycling Coaching by Cem Üner',
      description: 'Professional indoor cycling instruction and fitness coaching',
      provider: {
        '@id': 'https://cemuener.de/#person'
      },
      serviceType: ['Indoor Cycling', 'Fitness Coaching', 'Group Classes']
    }
  ]
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Alternate Language Links for International SEO -->
  <link rel="alternate" hreflang="de" href={`https://cemuener.de/de/${service}/`} />
  <link rel="alternate" hreflang="en" href={`https://cemuener.de/en/${service}/`} />
  <link rel="alternate" hreflang="x-default" href={`https://cemuener.de/de/${service}/`} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content={String(ogImageWidth)} />
  <meta property="og:image:height" content={String(ogImageHeight)} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:alt" content={title} />
  <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'de_DE'} />
  <meta property="og:locale:alternate" content={lang === 'en' ? 'de_DE' : 'en_US'} />
  <meta property="og:site_name" content="DJ Cem Üner" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImageURL} />
  <meta property="twitter:image:alt" content={title} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={faviconPath} />
  <!-- Thumbnail hint for crawlers -->
  <link rel="image_src" href={imageSrcURL} />


  <!-- Theme Color -->
  <meta name="theme-color" content="#FF006E" />
  <meta name="msapplication-TileColor" content="#FF006E" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <!-- Additional SEO Meta Tags -->
  <meta name="author" content="Cem Üner" />
  <meta name="keywords" content="DJ München, DJ Germany, House DJ, Afro House DJ, Oriental Music DJ, DJ Booking, Indoor Cycling Coach München, ICG Instructor, Fitness Coach Germany, Full-Stack Developer Germany, TypeScript Developer, React Developer, Munich DJ, Hochzeits DJ, Event DJ, Cem Üner" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

  <!-- Language and Geographic Meta Tags -->
  <meta name="language" content="German" />
  <meta name="geo.region" content="DE" />
  <meta name="geo.placename" content="Germany" />

  <!-- Structured Data (JSON-LD) for SEO and LLM Discovery -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <slot name="head" />
</head>
<body>
  <slot />
  {!hideFooter && <Footer />}
  <script src="../scripts/animations.ts"></script>
</body>
</html>

<style lang="scss" is:global>
  @use '../styles/main.scss';
</style>

