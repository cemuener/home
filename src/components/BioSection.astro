---
import type { Event } from '../types';
import eventsData from '../data/events.json';
import { translations } from '../i18n/translations';
import { MapPin, Clock } from '@lucide/astro';

const t = translations.de;
const events = eventsData as Event[];

const upcomingEvents = events
  .filter(event => event.status === 'upcoming')
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = events
  .filter(event => event.status === 'past' || event.status === 'highlight')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<section class="dj-section" id="bio">
  <div class="dj-section__container">
    <header class="dj-section__header reveal">
      <h2 class="dj-section__title text--gradient-dj" data-i18n="bio.title">{t.bio.title}</h2>
      <p class="dj-section__subtitle" data-i18n="bio.subtitle">{t.bio.subtitle}</p>
    </header>

    <div class="dj-section__bio reveal reveal--fade" style="transition-delay:0.15s">
      <p data-i18n="bio.bioPara1">
        {t.bio.bioPara1}
      </p>
      <p data-i18n="bio.bioPara2">
        {t.bio.bioPara2}
      </p>
    </div>

    {upcomingEvents.length > 0 && (
      <div class="dj-section__events">
        <h3 class="dj-section__section-title reveal" data-i18n="bio.upcomingEvents">{t.bio.upcomingEvents}</h3>
        <div class="dj-section__event-list reveal-children" data-stagger-step="90">
          {upcomingEvents.map((event) => (
            <article class="dj-section__event-card" key={event.id}>
              {event.url ? (
                <a href={event.url} target="_blank" rel="noopener noreferrer" class="dj-section__event-link">
                  <div class="dj-section__event-date">
                    <span class="dj-section__event-day">
                      {new Date(event.date).getDate()}
                    </span>
                    <span class="dj-section__event-month">
                      {new Intl.DateTimeFormat('de-DE', { month: 'short' }).format(
                        new Date(event.date)
                      )}
                    </span>
                  </div>
                  <div class="dj-section__event-content">
                    <h4 class="dj-section__event-title">{event.title}</h4>
                    <p class="dj-section__event-venue"><MapPin size={14} class="dj-event-icon" aria-hidden="true" /> {event.venue}</p>
                    {event.time && (
                      <p class="dj-section__event-time"><Clock size={14} class="dj-event-icon" aria-hidden="true" /> {event.time}</p>
                    )}
                    {event.description && (
                      <p class="dj-section__event-description">
                        {event.description}
                      </p>
                    )}
                    <span class="dj-section__event-type dj-section__event-type--{event.type}">
                      {event.type}
                    </span>
                  </div>
                </a>
              ) : (
                <>
                  <div class="dj-section__event-date">
                    <span class="dj-section__event-day">
                      {new Date(event.date).getDate()}
                    </span>
                    <span class="dj-section__event-month">
                      {new Intl.DateTimeFormat('de-DE', { month: 'short' }).format(
                        new Date(event.date)
                      )}
                    </span>
                  </div>
                  <div class="dj-section__event-content">
                    <h4 class="dj-section__event-title">{event.title}</h4>
                    <p class="dj-section__event-venue"><MapPin size={14} class="dj-event-icon" aria-hidden="true" /> {event.venue}</p>
                    {event.time && (
                      <p class="dj-section__event-time"><Clock size={14} class="dj-event-icon" aria-hidden="true" /> {event.time}</p>
                    )}
                    {event.description && (
                      <p class="dj-section__event-description">
                        {event.description}
                      </p>
                    )}
                    <span class="dj-section__event-type dj-section__event-type--{event.type}">
                      {event.type}
                    </span>
                  </div>
                </>
              )}
            </article>
          ))}
        </div>
      </div>
    )}

    {pastEvents.length > 0 && (
      <div class="dj-section__events dj-section__events--past">
        <details class="dj-section__past-events-details">
          <summary class="dj-section__past-events-toggle reveal">
            <span class="dj-section__past-events-toggle-label" data-i18n="bio.showPastEvents">{t.bio.showPastEvents}</span>
            <span class="dj-section__past-events-count">({pastEvents.length})</span>
            <svg class="dj-section__past-events-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="dj-section__event-list dj-section__event-list--past">
            {pastEvents.map((event) => (
              <article class={`dj-section__event-card dj-section__event-card--past${event.status === 'highlight' ? ' dj-section__event-card--highlight' : ''}`} key={event.id}>
                {event.url ? (
                  <a href={event.url} target="_blank" rel="noopener noreferrer" class="dj-section__event-link">
                    <div class="dj-section__event-date">
                      <span class="dj-section__event-day">
                        {new Date(event.date).getDate()}
                      </span>
                      <span class="dj-section__event-month">
                        {new Intl.DateTimeFormat('de-DE', { month: 'short' }).format(
                          new Date(event.date)
                        )}
                      </span>
                    </div>
                    <div class="dj-section__event-content">
                      <h4 class="dj-section__event-title">{event.title}</h4>
                      <p class="dj-section__event-venue"><MapPin size={14} class="dj-event-icon" aria-hidden="true" /> {event.venue}</p>
                      {event.time && (
                        <p class="dj-section__event-time"><Clock size={14} class="dj-event-icon" aria-hidden="true" /> {event.time}</p>
                      )}
                      {event.description && (
                        <p class="dj-section__event-description">{event.description}</p>
                      )}
                      <span class="dj-section__event-type dj-section__event-type--{event.type}">
                        {event.type}
                      </span>
                    </div>
                  </a>
                ) : (
                  <>
                    <div class="dj-section__event-date">
                      <span class="dj-section__event-day">
                        {new Date(event.date).getDate()}
                      </span>
                      <span class="dj-section__event-month">
                        {new Intl.DateTimeFormat('de-DE', { month: 'short' }).format(
                          new Date(event.date)
                        )}
                      </span>
                    </div>
                    <div class="dj-section__event-content">
                      <h4 class="dj-section__event-title">{event.title}</h4>
                      <p class="dj-section__event-venue"><MapPin size={14} class="dj-event-icon" aria-hidden="true" /> {event.venue}</p>
                      {event.time && (
                        <p class="dj-section__event-time"><Clock size={14} class="dj-event-icon" aria-hidden="true" /> {event.time}</p>
                      )}
                      {event.description && (
                        <p class="dj-section__event-description">{event.description}</p>
                      )}
                      <span class="dj-section__event-type dj-section__event-type--{event.type}">
                        {event.type}
                      </span>
                    </div>
                  </>
                )}
              </article>
            ))}
          </div>
        </details>
      </div>
    )}
  </div>
</section>

<style>
  .dj-section__event-venue,
  .dj-section__event-time {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  :global(.dj-event-icon) {
    flex-shrink: 0;
    opacity: 0.75;
  }
</style>
