---
import { translations } from '../i18n/translations';

export interface Props {
  service?: 'dj' | 'developer';
}

const { service = 'dj' } = Astro.props;

const t = translations.de;

const djNavItems = [
  { id: 'hero',          label: 'Home',                    dataI18n: '' },
  { id: 'bio',           label: t.nav.bio,                 dataI18n: 'nav.bio' },
  { id: 'mixtapes',      label: t.nav.mixtapes,            dataI18n: 'nav.mixtapes' },
  { id: 'testimonials',  label: t.nav.references,          dataI18n: 'nav.references' },
  { id: 'contact',       label: t.nav.contact,             dataI18n: 'nav.contact' },
];

const devNavItems = [
  { id: 'about',    label: t.nav.about,    dataI18n: 'nav.about' },
  { id: 'skills',   label: t.nav.skills,   dataI18n: 'nav.skills' },
  { id: 'projects', label: t.nav.projects, dataI18n: 'nav.projects' },
  { id: 'cv',       label: t.nav.cv,       dataI18n: 'nav.cv' },
];

const navItems = service === 'developer' ? devNavItems : djNavItems;
---

<aside class="scroll-nav" aria-label="Page sections navigation" data-service={service}>
  <ul class="scroll-nav__list">
    {navItems.map((item) => (
      <li class="scroll-nav__item">
        <a
          href={`#${item.id}`}
          class="scroll-nav__link"
          data-section={item.id}
          aria-label={`Go to ${item.label} section`}
          title={item.label}
        >
          <span class="scroll-nav__dot"></span>
          <span class="scroll-nav__label" data-i18n={item.dataI18n || ''}>
            {item.label}
          </span>
        </a>
      </li>
    ))}
    <li class="scroll-nav__item scroll-nav__item--top">
      <button
        class="scroll-nav__top-btn"
        id="scroll-top-btn"
        aria-label="Scroll to top"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
        <span class="scroll-nav__label scroll-nav__top-label">Scroll to top</span>
      </button>
    </li>
  </ul>
</aside>

<script>
  // Scroll navigation functionality
  const scrollNav = document.querySelector('.scroll-nav') as HTMLElement | null;
  const scrollLinks = document.querySelectorAll('.scroll-nav__link');
  const sections = document.querySelectorAll('section[id]');

  // Smooth scroll to section
  scrollLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('href');
      const targetSection = targetId ? document.querySelector(targetId) : null;

      if (targetSection) {
        // Update URL hash
        window.history.replaceState(null, '', targetId);

        // Smooth scroll to section
        targetSection.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });

  // Update active dot based on scroll position
  function updateActiveDot() {
    const scrollPosition = window.scrollY + window.innerHeight / 2;

    sections.forEach(section => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionHeight = (section as HTMLElement).offsetHeight;
      const sectionId = section.getAttribute('id');

      if (scrollPosition >= sectionTop && scrollPosition < sectionTop + sectionHeight) {
        scrollLinks.forEach(link => {
          link.classList.remove('scroll-nav__link--active');
          if (link.getAttribute('data-section') === sectionId) {
            link.classList.add('scroll-nav__link--active');
          }
        });
      }
    });

    // Show/hide scroll nav based on scroll position
    if (window.scrollY > 200) {
      scrollNav?.classList.add('scroll-nav--visible');
    } else {
      scrollNav?.classList.remove('scroll-nav--visible');
    }
  }

  // Throttled scroll handler for performance
  let scrollTicking = false;
  window.addEventListener('scroll', () => {
    if (!scrollTicking) {
      window.requestAnimationFrame(() => {
        updateActiveDot();
        scrollTicking = false;
      });
      scrollTicking = true;
    }
  });

  // Initial check
  updateActiveDot();

  // Scroll to top button
  document.getElementById('scroll-top-btn')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    window.history.replaceState(null, '', window.location.pathname);
  });
</script>

