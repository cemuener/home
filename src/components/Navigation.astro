---
import { translations } from '../i18n/translations';

export interface Props {
  service?: 'dj' | 'developer';
}

const { service = 'dj' } = Astro.props;
const t = translations;

// Derive current lang from URL so the logo href is correct for crawlers (no JS needed)
const currentPath = Astro.url.pathname;
const langMatch = currentPath.match(/^\/(de|en)\//);
const currentLang = langMatch ? langMatch[1] : 'de';
const logoHref = `/${currentLang}/${service}/`;

const djNavItems = [
  { href: '#bio',          section: 'bio',          i18n: 'nav.bio',       label: t.de.nav.bio },
  { href: '#mixtapes',     section: 'mixtapes',     i18n: 'nav.mixtapes',  label: t.de.nav.mixtapes },
  { href: '#testimonials', section: 'testimonials', i18n: 'nav.references',label: t.de.nav.references },
  { href: '#contact',      section: 'contact',      i18n: 'nav.contact',   label: t.de.nav.contact },
];

const devNavItems = [
  { href: '#about',    section: 'about',    i18n: 'nav.about',    label: t.de.nav.about },
  { href: '#skills',   section: 'skills',   i18n: 'nav.skills',   label: t.de.nav.skills },
  { href: '#projects', section: 'projects', i18n: 'nav.projects', label: t.de.nav.projects },
  { href: '#cv',       section: 'cv',       i18n: 'nav.cv',       label: t.de.nav.cv },
];

const navItems = service === 'developer' ? devNavItems : djNavItems;
---

<nav class="navigation" id="main-nav">
  <div class="navigation__container">
    <a href={logoHref} class="navigation__logo" id="logo-link">
      <span class="navigation__logo-text">cem.uener</span>
    </a>

    <ul class="navigation__menu" id="nav-menu">
      {navItems.map(item => (
        <li class="navigation__item">
          <a href={item.href} class="navigation__link" data-section={item.section}>
            <span data-i18n={item.i18n}>{item.label}</span>
          </a>
        </li>
      ))}
      <li class="navigation__menu-lang" id="menu-lang">
        <button class="navigation__menu-lang-btn navigation__menu-lang-btn--active" data-lang="de" id="menu-lang-de">DE</button>
        <span class="navigation__menu-lang-divider">/</span>
        <button class="navigation__menu-lang-btn" data-lang="en" id="menu-lang-en">EN</button>
      </li>
    </ul>
    <div class="navigation__actions">
      <button
          class="navigation__lang-toggle"
          id="lang-toggle"
          aria-label="Switch language"
          title="Switch language"
      >
        <span class="navigation__lang-current" data-lang="de">DE</span>
        <span class="navigation__lang-divider">/</span>
        <span class="navigation__lang-option" data-lang="en">EN</span>
      </button>

      <button
          class="navigation__toggle"
          id="nav-toggle"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="nav-menu"
      >
        <span class="navigation__toggle-icon"></span>
      </button>
    </div>
  </div>
</nav>

<script>
  import { translations } from '../i18n/translations';
  import { getStoredLanguage, setStoredLanguage, getCurrentLanguage } from '../i18n/utils';

  type Language = 'de' | 'en';

  // Initialize language from localStorage or default to 'de'
  let currentLang: Language = getStoredLanguage();
  document.documentElement.setAttribute('lang', currentLang);

  // Update UI to match stored language
  function updateLanguageUI(lang: Language) {
    const langToggle = document.getElementById('lang-toggle');
    if (langToggle) {
      const deSpan = langToggle.querySelector('[data-lang="de"]');
      const enSpan = langToggle.querySelector('[data-lang="en"]');

      if (lang === 'de') {
        deSpan?.classList.add('navigation__lang-current');
        deSpan?.classList.remove('navigation__lang-option');
        enSpan?.classList.add('navigation__lang-option');
        enSpan?.classList.remove('navigation__lang-current');
      } else {
        enSpan?.classList.add('navigation__lang-current');
        enSpan?.classList.remove('navigation__lang-option');
        deSpan?.classList.add('navigation__lang-option');
        deSpan?.classList.remove('navigation__lang-current');
      }
    }

    // Update mobile menu lang buttons
    const menuLangDe = document.getElementById('menu-lang-de');
    const menuLangEn = document.getElementById('menu-lang-en');
    if (lang === 'de') {
      menuLangDe?.classList.add('navigation__menu-lang-btn--active');
      menuLangEn?.classList.remove('navigation__menu-lang-btn--active');
    } else {
      menuLangEn?.classList.add('navigation__menu-lang-btn--active');
      menuLangDe?.classList.remove('navigation__menu-lang-btn--active');
    }
  }

  // Update all translatable elements
  function updateContent(lang: Language) {
    const t = translations[lang];

    document.querySelectorAll('[data-i18n]').forEach(element => {
      const key = element.getAttribute('data-i18n');
      if (key) {
        const keys = key.split('.');
        let value: any = t;
        for (const k of keys) {
          value = value?.[k];
        }
        if (value) {
          element.textContent = value;
        }
      }
    });
  }

  // Update logo link to respect current language
  function updateLogoLink(lang: Language) {
    const logoLink = document.getElementById('logo-link') as HTMLAnchorElement | null;
    if (logoLink) {
      const service = (window.location.pathname.includes('/developer') ? 'developer' : 'dj');
      logoLink.href = `/${lang}/${service}/`;
    }
  }

  // Logo click: scroll to top if already on a section page, otherwise navigate
  const logoLink = document.getElementById('logo-link') as HTMLAnchorElement | null;
  logoLink?.addEventListener('click', (e) => {
    const hasSections = document.querySelectorAll('section[id]').length > 0;
    if (hasSections) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
      // Clear hash from URL
      window.history.replaceState(null, '', window.location.pathname);
      // Remove active state from nav links
      document.querySelectorAll('.navigation__link--active').forEach(el => {
        el.classList.remove('navigation__link--active');
      });
    }
    // else: follow the href normally (navigate to language root)
  });

  // Initialize UI with stored language
  updateLanguageUI(currentLang);
  updateContent(currentLang);
  updateLogoLink(currentLang);

  // Scroll spy and smooth scrolling functionality
  const nav = document.getElementById('main-nav');
  const navLinks = document.querySelectorAll('.navigation__link');
  const navToggle = document.getElementById('nav-toggle');
  const navMenu = document.getElementById('nav-menu');
  const langToggle = document.getElementById('lang-toggle');
  const sections = document.querySelectorAll('section[id]');

  // Language toggle (desktop)
  langToggle?.addEventListener('click', () => {
    currentLang = currentLang === 'de' ? 'en' : 'de';
    setStoredLanguage(currentLang, true);
    updateLanguageUI(currentLang);
    updateContent(currentLang);
    updateLogoLink(currentLang);
    window.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang: currentLang } }));
  });

  // Language toggle (mobile menu)
  function switchLang(lang: Language) {
    currentLang = lang;
    setStoredLanguage(currentLang, true);
    updateLanguageUI(currentLang);
    updateContent(currentLang);
    updateLogoLink(currentLang);
    window.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang: currentLang } }));
  }
  document.getElementById('menu-lang-de')?.addEventListener('click', () => switchLang('de'));
  document.getElementById('menu-lang-en')?.addEventListener('click', () => switchLang('en'));

  // Smooth scrolling for anchor links
  navLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('href');
      const targetSection = targetId ? document.querySelector(targetId) : null;

      if (targetSection) {
        // Update URL hash
        window.history.replaceState(null, '', targetId);

        // Smooth scroll to section
        targetSection.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });

        // Close mobile menu after click
        if (navMenu) {
          navMenu.classList.remove('navigation__menu--open');
          navToggle?.setAttribute('aria-expanded', 'false');
        }
      }
    });
  });

  // Mobile menu toggle
  navToggle?.addEventListener('click', () => {
    const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
    navToggle.setAttribute('aria-expanded', String(!isExpanded));
    navMenu?.classList.toggle('navigation__menu--open');
  });

  // Scroll spy - highlight active section
  let lastScrollY = window.scrollY;

  function highlightNavOnScroll() {
    const scrollY = window.scrollY;
    const scrollPosition = scrollY + 100; // Offset for better UX
    let currentSection = '';

    sections.forEach(section => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionHeight = (section as HTMLElement).offsetHeight;
      const sectionId = section.getAttribute('id');

      if (scrollPosition >= sectionTop && scrollPosition < sectionTop + sectionHeight) {
        currentSection = sectionId || '';
        navLinks.forEach(link => {
          link.classList.remove('navigation__link--active');
          if (link.getAttribute('data-section') === sectionId) {
            link.classList.add('navigation__link--active');
          }
        });
      }
    });

    // Update URL hash if section changed
    if (currentSection && window.location.hash !== `#${currentSection}`) {
      window.history.replaceState(null, '', `#${currentSection}`);
    }

    // Add background to nav on scroll
    if (scrollY > 50) {
      nav?.classList.add('navigation--scrolled');
    } else {
      nav?.classList.remove('navigation--scrolled');
    }

    // Hide nav on scroll down, show on scroll up
    const heroHeight = (document.querySelector('section#bio') as HTMLElement)?.offsetTop ?? 600;
    if (scrollY > lastScrollY && scrollY > heroHeight) {
      nav?.classList.add('navigation--hidden');
    } else {
      nav?.classList.remove('navigation--hidden');
    }
    lastScrollY = scrollY;
  }

  // Throttle scroll event for performance
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        highlightNavOnScroll();
        ticking = false;
      });
      ticking = true;
    }
  });

  // Initial check
  highlightNavOnScroll();
</script>

