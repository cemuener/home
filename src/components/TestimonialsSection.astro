---
import type { Testimonial } from '../types';
import testimonialsData from '../data/testimonials.json';
import { translations } from '../i18n/translations';

const t = translations.de;
const testimonials = testimonialsData as Testimonial[];

const djTestimonials = testimonials
  .filter(test => test.service === 'dj' && test.featured)
  .sort((a, b) => b.rating - a.rating);
---

<section class="testimonials-section" id="testimonials">
  <div class="testimonials-section__container">
    <header class="testimonials-section__header reveal">
      <h2 class="testimonials-section__title text--gradient-dj" data-i18n="testimonials.title">{t.testimonials.title}</h2>
      <p class="testimonials-section__subtitle" data-i18n="testimonials.subtitle">
        {t.testimonials.subtitle}
      </p>
    </header>

    {djTestimonials.length > 0 ? (
      <div class="testimonials-carousel reveal reveal--fade" style="transition-delay:0.2s" aria-label="Testimonials carousel">
        <button class="testimonials-carousel__btn testimonials-carousel__btn--prev" aria-label="Previous testimonial">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="testimonials-carousel__track" id="testimonials-track">
          {djTestimonials.map((testimonial, idx) => (
            <article class="testimonial-card" data-index={idx}>
              <div class="testimonial-card__header">
                {testimonial.photo && (
                  <img
                    src={testimonial.photo}
                    alt={testimonial.name}
                    class="testimonial-card__photo"
                    loading="lazy"
                    width="60"
                    height="60"
                  />
                )}
                <div class="testimonial-card__meta">
                  <h3 class="testimonial-card__name">{testimonial.name}</h3>
                  {testimonial.role && (
                    <p class="testimonial-card__role">{testimonial.role}</p>
                  )}
                  <div class="testimonial-card__rating" aria-label={`Rating: ${testimonial.rating} out of 5 stars`}>
                    {Array.from({ length: 5 }).map((_, i) => (
                      <span class={`testimonial-card__star ${i < testimonial.rating ? 'testimonial-card__star--filled' : ''}`}>★</span>
                    ))}
                  </div>
                </div>
              </div>

              <blockquote class="testimonial-card__quote">
                <p>{testimonial.text}</p>
              </blockquote>

              <footer class="testimonial-card__footer">
                <time class="testimonial-card__date" datetime={testimonial.date}>
                  {new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'long' }).format(new Date(testimonial.date))}
                </time>
                <span class="testimonial-card__service testimonial-card__service--{testimonial.service}">
                  <span data-i18n="testimonials.djService">{t.testimonials.djService}</span>
                </span>
              </footer>
            </article>
          ))}
        </div>

        <button class="testimonials-carousel__btn testimonials-carousel__btn--next" aria-label="Next testimonial">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <div class="testimonials-carousel__dots" id="testimonials-dots">
          {djTestimonials.map((_, idx) => (
            <button class={`testimonials-carousel__dot ${idx === Math.floor(djTestimonials.length / 2) ? 'testimonials-carousel__dot--active' : ''}`} aria-label={`Go to testimonial ${idx + 1}`} data-dot={idx} />
          ))}
        </div>
      </div>
    ) : (
      <div class="testimonials-section__empty">
        <p>More testimonials coming soon!</p>
      </div>
    )}
  </div>
</section>

<script>
  const track = document.getElementById('testimonials-track');
  const dotsContainer = document.getElementById('testimonials-dots');

  if (track) {
    const cards = Array.from(track.querySelectorAll<HTMLElement>('.testimonial-card'));
    const dots = dotsContainer ? Array.from(dotsContainer.querySelectorAll<HTMLElement>('.testimonials-carousel__dot')) : [];
    const total = cards.length;
    let current = Math.floor(total / 2);

    const DESKTOP_BP = 1024;

    // ── Desktop gallery mode ──────────────────────────────────────────────
    const syncTrackHeight = () => {
      const activeCard = cards[current];
      const h = activeCard.offsetHeight;
      track.style.height = h + 'px';
      // set CSS var on the carousel wrapper so &__btn can read it
      const carousel = track.closest<HTMLElement>('.testimonials-carousel');
      if (carousel) carousel.style.setProperty('--track-height', h + 'px');
    };

    const applyGalleryState = () => {
      cards.forEach((card, i) => {
        card.classList.remove('is-active', 'is-prev', 'is-next', 'is-hidden');
        const offset = ((i - current) % total + total) % total;
        if (offset === 0) {
          card.classList.add('is-active');
        } else if (offset === 1) {
          card.classList.add('is-next');
        } else if (offset === total - 1) {
          card.classList.add('is-prev');
        } else {
          card.classList.add('is-hidden');
        }
      });
      dots.forEach((d, i) => d.classList.toggle('testimonials-carousel__dot--active', i === current));
      syncTrackHeight();
    };

    const galleryGo = (idx: number) => {
      current = ((idx % total) + total) % total;
      applyGalleryState();
    };

    // ── Mobile scroll mode ────────────────────────────────────────────────
    const scrollTo = (idx: number) => {
      current = Math.max(0, Math.min(idx, total - 1));
      cards[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      dots.forEach((d, i) => d.classList.toggle('testimonials-carousel__dot--active', i === current));
    };

    // ── Mode switching ────────────────────────────────────────────────────
    let desktopMode = false;

    const enableDesktopMode = () => {
      if (desktopMode) return;
      desktopMode = true;
      track.style.overflowX = 'clip';
      applyGalleryState();
      // clicking side cards navigates
      cards.forEach((card) => {
        card.addEventListener('click', () => {
          if (card.classList.contains('is-prev')) galleryGo(current - 1);
          else if (card.classList.contains('is-next')) galleryGo(current + 1);
        });
      });
    };

    const enableMobileMode = () => {
      if (!desktopMode) return;
      desktopMode = false;
      cards.forEach(card => card.classList.remove('is-active', 'is-prev', 'is-next', 'is-hidden'));
      track.style.overflowX = '';
      track.style.height = '';
      track.style.removeProperty('--track-height');
      const carousel = track.closest<HTMLElement>('.testimonials-carousel');
      if (carousel) carousel.style.removeProperty('--track-height');
      scrollTo(current);
    };

    const checkMode = () => {
      if (window.innerWidth >= DESKTOP_BP) enableDesktopMode();
      else enableMobileMode();
    };

    checkMode();
    window.addEventListener('resize', () => {
      checkMode();
      if (desktopMode) syncTrackHeight();
    });

    // Prev / Next buttons
    document.querySelector('.testimonials-carousel__btn--prev')?.addEventListener('click', () => {
      if (desktopMode) galleryGo(current - 1);
      else scrollTo(current - 1);
    });
    document.querySelector('.testimonials-carousel__btn--next')?.addEventListener('click', () => {
      if (desktopMode) galleryGo(current + 1);
      else scrollTo(current + 1);
    });

    // Dot navigation
    dots.forEach((dot, i) => dot.addEventListener('click', () => {
      if (desktopMode) galleryGo(i);
      else scrollTo(i);
    }));

    // Mobile scroll → update active dot via IntersectionObserver
    const observer = new IntersectionObserver((entries) => {
      if (desktopMode) return;
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = cards.indexOf(entry.target as HTMLElement);
          if (idx !== -1) {
            current = idx;
            dots.forEach((d, i) => d.classList.toggle('testimonials-carousel__dot--active', i === current));
          }
        }
      });
    }, { root: track, threshold: 0.6 });

    cards.forEach(card => observer.observe(card));

    // Keyboard support
    document.addEventListener('keydown', (e) => {
      if (!desktopMode) return;
      if (e.key === 'ArrowLeft') galleryGo(current - 1);
      if (e.key === 'ArrowRight') galleryGo(current + 1);
    });
  }
</script>
