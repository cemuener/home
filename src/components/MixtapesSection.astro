---
import type { Mix } from '../types';
import mixesData from '../data/mixes.json';
import { translations } from '../i18n/translations';

const t = translations.de;
const mixes = mixesData as Mix[];

const featuredMixes = mixes
  .filter(mix => mix.featured)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('de-DE', {
    month: 'short',
    year: 'numeric'
  }).format(date);
};
---

<section class="dj-section" id="mixtapes">
  <div class="dj-section__container">
    <header class="dj-section__header reveal">
      <h2 class="dj-section__title text--gradient-dj" data-i18n="mixtapes.title">{t.mixtapes.title}</h2>
      <p class="dj-section__subtitle" data-i18n="mixtapes.subtitle">{t.mixtapes.subtitle}</p>
    </header>

    {featuredMixes.length > 0 && (
      <div class="dj-section__mixes">
        <div class="dj-section__mix-grid reveal-children" data-stagger-step="70" data-reveal-variant="scale">
          {featuredMixes.map((mix) => (
            <a
              href={mix.embedUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="dj-section__mix-card"
              aria-label={`${mix.title} – ${t.mixtapes.listenOn}`}
            >
              <div class="dj-section__mix-cover">
                <img
                  src={mix.coverImage}
                  alt={`${mix.title} Cover`}
                  loading="lazy"
                  width="400"
                  height="400"
                />
                <div class="dj-section__mix-overlay">
                  <span class="dj-section__mix-duration">{mix.duration}</span>
                </div>
              </div>
              <div class="dj-section__mix-content">
                <h4 class="dj-section__mix-title">{mix.title}</h4>
                <p class="dj-section__mix-date">{formatDate(mix.date)}</p>
                <div class="dj-section__mix-genres">
                  {mix.genres.map((genre) => (
                    <span class="dj-section__genre-tag">{genre}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

