---
import { translations } from '../i18n/translations';

const t = translations.de;
---

<section class="contact-section" id="contact">
  <div class="contact-section__container">
    <header class="contact-section__header">
      <h2 class="contact-section__title text--gradient-dj" data-i18n="contact.title">{t.contact.title}</h2>
      <p class="contact-section__subtitle" data-i18n="contact.subtitle">
        {t.contact.subtitle}
      </p>
    </header>

    <div class="contact-section__content">
      <form
        class="contact-form"
        id="contact-form"
        action="https://formspree.io/f/xgorvzkd"
        method="POST"
        novalidate
      >
        <!-- Honeypot field for spam protection -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="contact-form__field">
          <label for="name" class="contact-form__label">
            <span data-i18n="contact.form.name">{t.contact.form.name}</span> <span class="contact-form__required">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            class="contact-form__input"
            required
            aria-required="true"
            aria-describedby="name-error"
          />
          <span class="contact-form__error" id="name-error" role="alert"></span>
        </div>

        <div class="contact-form__field">
          <label for="email" class="contact-form__label">
            <span data-i18n="contact.form.email">{t.contact.form.email}</span> <span class="contact-form__required">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            class="contact-form__input"
            required
            aria-required="true"
            aria-describedby="email-error"
          />
          <span class="contact-form__error" id="email-error" role="alert"></span>
        </div>

        <div class="contact-form__field">
          <label for="subject" class="contact-form__label">
            <span data-i18n="contact.form.subject">{t.contact.form.subject}</span> <span class="contact-form__required">*</span>
          </label>
          <input
            type="text"
            id="subject"
            name="subject"
            class="contact-form__input"
            required
            aria-required="true"
            aria-describedby="subject-error"
          />
          <span class="contact-form__error" id="subject-error" role="alert"></span>
        </div>

        <div class="contact-form__field">
          <label for="message" class="contact-form__label">
            <span data-i18n="contact.form.message">{t.contact.form.message}</span> <span class="contact-form__required">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            class="contact-form__textarea"
            rows="6"
            required
            aria-required="true"
            aria-describedby="message-error"
          ></textarea>
          <span class="contact-form__error" id="message-error" role="alert"></span>
        </div>

        <div class="contact-form__actions">
          <button type="submit" class="contact-form__submit">
            <span class="contact-form__submit-text" data-i18n="contact.form.submit">{t.contact.form.submit}</span>
            <span class="contact-form__submit-loading" data-i18n="contact.form.sending">{t.contact.form.sending}</span>
          </button>
        </div>

        <div class="contact-form__message contact-form__message--success" hidden role="status">
          <span data-i18n="contact.form.success">{t.contact.form.success}</span>
        </div>

        <div class="contact-form__message contact-form__message--error" hidden role="alert">
          <span data-i18n="contact.form.error">{t.contact.form.error}</span>
        </div>
      </form>

      <div class="contact-section__social">
        <h3 class="contact-section__social-title" data-i18n="contact.social.title">{t.contact.social.title}</h3>
        <div class="contact-section__social-grid">
          <a
            href="https://instagram.com/cem.uener"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-section__social-link"
            aria-label="Follow me on Instagram"
          >
            <svg class="contact-section__social-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            <span>Instagram</span>
          </a>

          <a
            href="https://soundcloud.com/cemuener"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-section__social-link"
            aria-label="Listen on SoundCloud"
          >
            <img src="/assets/icons/soundcloud.png" alt="SoundCloud" class="contact-section__social-icon" />
            <span>SoundCloud</span>
          </a>

          <a
            href="https://linkedin.com/in/cemuener"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-section__social-link"
            aria-label="Connect on LinkedIn"
          >
            <svg class="contact-section__social-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span>LinkedIn</span>
          </a>

          <a
            href="https://github.com/cemuener"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-section__social-link"
            aria-label="View code on GitHub"
          >
            <svg class="contact-section__social-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
            <span>GitHub</span>
          </a>
        </div>
      </div>
    </div>

    <footer class="contact-section__footer">
      <div class="contact-section__footer-content">
        <p class="contact-section__footer-text">
          &copy; {new Date().getFullYear()} Cem Üner. <span data-i18n="contact.footer.copyright">{t.contact.footer.copyright}</span>
        </p>
        <nav class="contact-section__footer-nav">
          <a href="/de/impressum" class="contact-section__footer-link" data-i18n="contact.footer.impressum" data-impressum-link="true">{t.contact.footer.impressum}</a>
        </nav>
      </div>
    </footer>
  </div>
</section>

<script>
  import { translations } from '../i18n/translations';
  import type { Language } from '../i18n/utils';

  // Contact form validation and submission
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const subjectInput = document.getElementById('subject') as HTMLInputElement;
    const messageInput = document.getElementById('message') as HTMLTextAreaElement;

    const submitBtn = form.querySelector('.contact-form__submit') as HTMLButtonElement;
    const submitText = form.querySelector('.contact-form__submit-text') as HTMLElement;
    const submitLoading = form.querySelector('.contact-form__submit-loading') as HTMLElement;
    const successMessage = form.querySelector('.contact-form__message--success') as HTMLDivElement;
    const errorMessage = form.querySelector('.contact-form__message--error') as HTMLDivElement;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    let currentLang: Language = (document.documentElement.getAttribute('lang') as Language) || 'de';

    function showError(input: HTMLInputElement | HTMLTextAreaElement, messageKey: string) {
      const t = translations[currentLang].contact.form;
      const message = messageKey === 'required' ? t.errorRequired : t.errorEmail;
      const errorSpan = document.getElementById(`${input.id}-error`) as HTMLSpanElement;
      if (errorSpan) {
        errorSpan.textContent = message;
        input.classList.add('contact-form__input--error');
        input.setAttribute('aria-invalid', 'true');
      }
    }

    function clearError(input: HTMLInputElement | HTMLTextAreaElement) {
      const errorSpan = document.getElementById(`${input.id}-error`) as HTMLSpanElement;
      if (errorSpan) {
        errorSpan.textContent = '';
        input.classList.remove('contact-form__input--error');
        input.setAttribute('aria-invalid', 'false');
      }
    }

    function validateField(input: HTMLInputElement | HTMLTextAreaElement): boolean {
      clearError(input);

      if (!input.value.trim()) {
        showError(input, 'required');
        return false;
      }

      if (input.type === 'email' && !emailRegex.test(input.value)) {
        showError(input, 'email');
        return false;
      }

      return true;
    }

    // Real-time validation on blur
    [nameInput, emailInput, subjectInput, messageInput].forEach(input => {
      input.addEventListener('blur', () => validateField(input));
      input.addEventListener('input', () => {
        if (input.classList.contains('contact-form__input--error')) {
          validateField(input);
        }
      });
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Validate all fields
      const isNameValid = validateField(nameInput);
      const isEmailValid = validateField(emailInput);
      const isSubjectValid = validateField(subjectInput);
      const isMessageValid = validateField(messageInput);

      if (!isNameValid || !isEmailValid || !isSubjectValid || !isMessageValid) {
        return;
      }

      // Show loading state
      submitBtn.disabled = true;
      submitText.hidden = true;
      submitLoading.hidden = false;
      successMessage.hidden = true;
      errorMessage.hidden = true;

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          // Success
          successMessage.hidden = false;
          form.reset();
        } else {
          // Error
          throw new Error('Form submission failed');
        }
      } catch (error) {
        errorMessage.hidden = false;
      } finally {
        // Reset button state
        submitBtn.disabled = false;
        submitText.hidden = false;
        submitLoading.hidden = true;
      }
    });

    // Update impressum link based on language
    function updateImpressumLink(lang: string) {
      document.querySelectorAll('[data-impressum-link]').forEach(el => {
        (el as HTMLAnchorElement).href = `/${lang}/impressum`;
      });
    }

    // Set initial impressum link
    updateImpressumLink(currentLang);

    // Listen for language changes
    window.addEventListener('languageChanged', ((e: CustomEvent) => {
      currentLang = e.detail.lang;
      updateImpressumLink(currentLang);
    }) as EventListener);
  }
</script>

